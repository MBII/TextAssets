	forcepowers			FP_SABER_OFFENSE,3|FP_SABER_DEFENSE,3|FP_LEVITATION,3|FP_LIGHTNING,3|FP_PUSH,2|FP_PULL,2|FP_DRAIN,2|FP_TEAM_HEAL,1
	maxhealth			100
