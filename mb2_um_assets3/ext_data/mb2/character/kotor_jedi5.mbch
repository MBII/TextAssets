//Siege class def file.

ClassInfo
{
	name				"kotor_jedi5"
	weapons				WP_MELEE|WP_SABER|WP_SONIC_NADE
	attributes			MB_ATT_FP_SABER_DEFENSE,3|MB_ATT_GUN_DEFENSE,2|MB_ATT_SONIC_DETONATOR,2|MB_ATT_ANTI_MT,1|MB_ATT_HEALING,1|MB_ATT_FORCEFOCUS,1|MB_ATT_FORCEBLOCK,3
	saber1				kotorsab
	sabercolor			5
	saber2				kotorsab
	saber2color			5
	saberstyle			SS_DUAL
	forcepowers			FP_SABER_OFFENSE,3|FP_SABER_DEFENSE,3|FP_LEVITATION,3|FP_PUSH,3|FP_PULL,3
	maxhealth			100
	maxarmor			0
	extraLives			2
	startarmor			0
	model				"Selkath" 					//this is optional, if it's here it forces the model to this.
	skin				"purple"					//this is optional, if it's here it forces the skin to this.
	uishader			"models/players/Selkath/MB2_Icon_purple"
	MBClass				MB_CLASS_JEDI
	classflags			CFL_ACIDBLOOD|CFL_DISMEMBERFRAGILE
