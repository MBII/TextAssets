//Siege class def file.

ClassInfo
{
	name				"dark_jedi2"
	weapons				WP_MELEE|WP_SABER
	attributes			MB_ATT_FP_SABER_DEFENSE,3|MB_ATT_GUN_DEFENSE,2|MB_ATT_ANTI_MT,1|MB_ATT_FORCEFOCUS,1|MB_ATT_FORCEBLOCK,3|MB_ATT_DISP_HEALTH,3
	saber1 				saber_visas
	sabercolor			0
	saber2				saber_visas
	saber2color			0
	saberstyle			SS_DUAL
	forcepowers			FP_SABER_OFFENSE,3|FP_SABER_DEFENSE,3|FP_LEVITATION,3|FP_PUSH,3|FP_PULL,3|FP_SEE,3
	maxhealth			100
	maxarmor			0
	extraLives			2
	startarmor			0
	model				"Visas" 					//this is optional, if it's here it forces the model to this.
	skin				"default"					//this is optional, if it's here it forces the skin to this.
	uishader			"models/players/visas/mb2_icon_default_sith"
	MBClass				MB_CLASS_JEDI
	classflags 			CFL_MIRALUKA|CFL_SEEING_STEALTH|CFL_STATVIEWER
	classNumberLimit	0
