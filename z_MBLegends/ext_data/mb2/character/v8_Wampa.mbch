ClassInfo
{
	name				"v8_Wampa"

	MBClass 			MB_CLASS_WOOKIE
 classNumberLimit	3
	weapons 		WP_MELEE|WP_STUN_BATON
	attributes MB_ATT_WOOKIE_STRENGTH,3|MB_ATT_WOOKIEE_FURY,3|MB_ATT_STUN_BATON,1|MB_ATT_HEALING,2|MB_ATT_BLAST_ARMOUR

 WP_StunBatonFlags HELD_SPEED
// WP_MeleeFlags HELD_FREEZE

	maxhealth	 240

	classflags		CFL_STRONGAGAINSTPHYSICAL|CFL_NOLOCATIONALDAMAGE|CFL_NODISMEMBER|CFL_BLOODYMELEE|CFL_NOPICKUPS
//humanoidSkeleton	1
	disableGunBash 1
 forcepowers FP_RAGE,3
 forcepool 45
 forceRegen 0.65
 resource RESOURCE_RAGE
 resourceRegenAmount 3
 resourceRegenRate 1000
 resourceRegenCap 45

	healthRegenAmount 5
	healthRegenRate 20000
	healthRegenCap 250

	DamageTaken		0.5
 knockbackTaken 0.2

 skillTimerMod 0.6
 baseSpeed 180

 special1 EAS_FP_RAGE
	special2	EAS_HI_BARGE
 //special3 eas_hi_ice

	hackRate 5

	meleeMoves M_BLOCK

 bargeSoundOverride		"sound/chars/wampa/misc/chase1.mp3"
 rageSoundOverride	"sound/chars/wampa/misc/chase2.mp3"

	modelscale	1.25
	uioverlay "gfx/icons/brawler"

	model	   "wampa"
	skin		   "default"
	uishader	"models/players/wampa_pl/icon_default"

 tauntAnim BOTH_GESTURE1
 gloatAnim BOTH_GESTURE2
 flourishAnim BOTH_HOLD_SNIFF
 bowAnim BOTH_ATTACK1
 meditateAnim BOTH_ATTACK2
 WalkForward BOTH_WALK1
 WalkBackward BOTH_RUNBACK1 //BOTH_WALK2
 RunForward BOTH_RUN2
 RunBackward BOTH_RUNBACK1
 deathAnim BOTH_CIN_2
 crouchAnim  BOTH_WALK2
 getupAnim BOTH_PAIN2
}

