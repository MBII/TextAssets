	attributes			MB_ATT_BLASTER,1|MB_ATT_PISTOL,2|MB_ATT_AMMO,3|MB_ATT_FIRE_GRENADES,2|MB_ATT_DEXTERITY,2|MB_ATT_STAMINA,2
	maxhealth			60
