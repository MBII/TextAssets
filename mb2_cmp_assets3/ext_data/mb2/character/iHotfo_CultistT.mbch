	name				"iHotfo_CultistT"
	weapons				WP_MELEE
	attributes			MB_ATT_DASH,1|MB_ATT_CORTOSIS,1|MB_ATT_WOOKIE_STRENGTH,1|MB_ATT_FORCEBLOCK,2|MB_ATT_FP_REPULSE,1|MB_ATT_FORCEFOCUS,2
	forcepowers			FP_LEVITATION,2|FP_PUSH,3|FP_PULL,3|FP_GRIP,3|FP_SPEED,1|FP_SEE,1
	forcepool			125
    forceregen			2.5
	maxhealth			100
	maxarmor			50
	speed				1
	model				"cultist"
	skin				"rgb"
	customred			1
	customgreen			1
	customblue			1
	uishader			"models/players/cultist/mb2_icon_white"
	MBClass 			MB_CLASS_JEDI
