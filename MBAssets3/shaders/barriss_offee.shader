models/players/barriss_offee/cloak
{
	cull	disable
	{
		map models/players/barriss_offee/cloak
		depthWrite
		rgbGen lightingDiffuse
	}
}

models/players/barriss_offee/cape
{
	cull	disable
	{
		map models/players/barriss_offee/cape
		depthWrite
		rgbGen lightingDiffuse
	}
}

models/players/barriss_offee/body_inq
{
        nopicmip
    {
        map models/players/barriss_offee/body_inq
        depthWrite
        rgbGen lightingDiffuse
    }
    {  
        map models/players/barriss_offee/body_inq_spec
		blendFunc GL_SRC_ALPHA GL_ONE
		alphaGen lightingSpecular
                detail
    }
    {
        map models/players/barriss_offee/body_inq_glow
		blendFunc GL_SRC_ALPHA GL_ONE
                rgbGen lightingDiffuse
		glow
                rgbGen identityLighting
                detail
    }
}

