models/players/11thbrother/armor
{
	cull	disable
	{
		map models/players/11thbrother/armor
		rgbGen lightingDiffuse
	}
	{
		map models/players/11thbrother/armor_spec
		blendFunc GL_SRC_ALPHA GL_ONE
		detail
		alphaGen lightingSpecular
	}
	{
		map models/players/11thbrother/armor_g
		blendFunc GL_ONE GL_ONE
		detail
		glow
	}
}

