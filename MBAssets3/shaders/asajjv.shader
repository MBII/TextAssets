models/players/assajv/head
{
	cull	disable
	{
		map models/players/assajv/head
		alphaFunc GE128
		depthWrite
		rgbGen lightingDiffuse
	}
	{
		map models/players/assajv/head_spec
		blendFunc GL_SRC_ALPHA GL_ONE
		alphaGen lightingSpecular
	}
}

