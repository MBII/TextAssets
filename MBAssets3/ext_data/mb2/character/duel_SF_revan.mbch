ClassInfo
{
	name				"duel_SF_revan"
	weapons				WP_MELEE|WP_SABER
	attributes			MB_ATT_FP_SABER_DEFENSE,3|MB_ATT_GUN_DEFENSE,2|MB_ATT_FORCEFOCUS,1|MB_ATT_FORCEBLOCK,1
	saber1				saber_revan
	sabercolor			4
	saberstyle			SS_MEDIUM|SS_FAST|SS_STRONG
	forcepowers			FP_LEVITATION,2|FP_PUSH,3|FP_SPEED,2|FP_LIGHTNING,1|FP_SABER_OFFENSE,3|FP_SABER_DEFENSE,3
	maxhealth			200
	maxarmor			0
