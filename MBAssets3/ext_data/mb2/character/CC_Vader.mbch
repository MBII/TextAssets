//Siege class def file.

ClassInfo
{
	name				"CC_Vader"
	weapons				WP_MELEE|WP_SABER
	attributes			MB_ATT_FP_SABER_DEFENSE,3|MB_ATT_GUN_DEFENSE,2|MB_ATT_FORCEFOCUS,1|MB_ATT_FORCEBLOCK,2|MB_ATT_DEFLECT,2
	saber1				saber_vader
	sabercolor			0
	saberstyle			SS_MEDIUM|SS_STRONG
	forcepowers			FP_SABER_OFFENSE,3|FP_SABER_DEFENSE,3|FP_LEVITATION,1|FP_PUSH,3|FP_PULL,2|FP_GRIP,3|FP_SEE,2
	maxhealth			100
	maxarmor			50
	modelscale			1.1
	model				"darthvader"
	skin				"default"
	uishader			"models/players/darthvader/mb2_icon_default"
