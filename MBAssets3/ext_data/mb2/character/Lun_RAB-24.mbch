	name				"Lun_RAB-24"
	weapons				WP_MELEE|WP_DISRUPTOR
	attributes			MB_ATT_DISRUPTOR,2|MB_ATT_TRACKING_DART,3|MB_ATT_AMMO,3|MB_ATT_SENTRY
	//holdables			HI_SENTRY_GUN
	maxhealth			100
	maxarmor			100
	model				"RAB-24"
