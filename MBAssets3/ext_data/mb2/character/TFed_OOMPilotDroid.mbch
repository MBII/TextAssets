//Siege class def file.

ClassInfo
{
	name				"TFed_OOMPilotDroid"
	weapons				WP_MELEE|WP_BLASTER_PISTOL
	attributes			MB_ATT_AMMO,2|MB_ATT_PISTOL,2|MB_ATT_HEALING,1|MB_ATT_DISP_HEALTH,3|MB_ATT_DISP_AMMO,3
	classflags			CFL_STATVIEWER
	maxhealth			65
	maxarmor			35
	speed				1.2
	model				"battledroid"
	skin				"ep1_pilot"
