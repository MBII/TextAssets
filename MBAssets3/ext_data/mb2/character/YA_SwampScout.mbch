//Siege class def file.

ClassInfo
{
	name				"YA_SwampScout"
	weapons				WP_BLASTER_PISTOL|WP_M5|WP_SONIC_NADE
	attributes			MB_ATT_WESTARM5,2|MB_ATT_ASSEMBLE,1|MB_ATT_HEALING,1|MB_ATT_AMMO,3|MB_ATT_PISTOL,2|MB_ATT_DEXTERITY,3|MB_ATT_STAMINA,3|MB_ATT_ARC_RIFLE_SCOPE,2|MB_ATT_SONIC_DETONATOR,2|MB_ATT_BINOCULARS
	//holdables			HI_BINOCULARS
	maxhealth			70
	maxarmor			25
	extralives			1
	model				"scouttrooper" 				//this is optional, if it's here it forces the model to this.
	skin				"swamp"					//this is optional, if it's here it forces the skin to this.
	uishader			"models/players/scouttrooper/mb2_icon_swamp"
	MBClass				MB_CLASS_ARCTROOPER
	classNumberLimit	2
}

WeaponInfo0
{
	WeaponToReplace		WP_BLASTER_PISTOL					//Required: Weapon Slot of weapon you're replacing
	WeaponBasedOff		WP_BLASTER_PISTOL					//Required: For future use, should be the same as WeaponToReplace
	NewWorldModel		"models/weapons2/scout_pistol/blaster_pistol_w.glm"  	//Required: New 3rd person/dropped weapon model
	NewViewModel		"models/weapons2/scout_pistol/blaster_pistol.md3"   	//Required: New 1st person weapon model
	Icon				"gfx/hud/w_icon_scout_pistol" 					//Required: Weapon change icon
	WeaponName			"EC-17 Holdout Blaster"    					//Required: Weapon change display name
}

WeaponInfo1
{
	WeaponToReplace		WP_M5
	WeaponBasedOff		WP_SBD
	NewWorldModel		"models/weapons2/dlt20a/dlt20a_w.glm"
	NewViewModel		"models/weapons2/dlt20a/dlt20a.md3"
	Icon				"gfx/hud/w_icon_DLT20a"
	WeaponName			"DLT-20a Blaster Rifle"
	MuzzleEffect		"Blaster/MuzzleFlash01R"   				//Optional: New muzzle effect
	AltMuzzleEffect		"Blaster/MuzzleFlash01R" 				//Optional: New alt muzzle effect
	MissileEffect		"Blaster/Shot01R"  					//Optional: New effect to be displayed on the projectile
	AltMissileEffect	"Blaster/Shot01R"
	Missile3Effect		"Blaster/Shot01R" 
}

description	"Remnant Swamp Scoutrooper

^2Weaponry:
- EC-17 Holdout Blaster Pistol (2)
- Modified DLT-20a Blaster Rifle (2)
-- Based on Westar M5 [Scope]
- 2 Sonic Detonators

^6Inventory:
- Electrobinoculars

^8Attributes:
- Stamina (3)
- Dexterity (3)
- Healing (1)
- Reinforcements (1)
- Assemble (1)

^3Abilities:
- Sprint ^3[CS1]
- Dex Roll ^3[CS2]

A scout trooper in the Imperial Remnant. Sports camouflage and a marksmans DLT-20a."