//Siege class def file.

ClassInfo
{
	name				"Ald_stormtrooper"
	weapons				WP_MELEE|WP_BLASTER|WP_FRAG_NADE
	attributes			MB_ATT_ASSEMBLE|MB_ATT_AMMO,3|MB_ATT_CCTRAINING,2|MB_ATT_QUICKTHROW,1|MB_ATT_FRAGS,1|MB_ATT_BLASTER,3
	maxhealth			40
	maxarmor			40
	extraLives			2
	speed				1.025
	model				"stormie" 				//this is optional, if it's here it forces the model to this.
	skin				"default"					//this is optional, if it's here it forces the skin to this.
	uishader			"models/players/stormie/mb2_icon_default"
	MBClass				MB_CLASS_SOLDIER
