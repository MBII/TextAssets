	BPmultiplier		0.8
	forcepowers			FP_SABER_OFFENSE,3|FP_SABER_DEFENSE,2|FP_LEVITATION,2|FP_PUSH,2|FP_GRIP,1|FP_SEE,1|FP_SABERTHROW,1|FP_LIGHTNING,1
	forcepool			100
