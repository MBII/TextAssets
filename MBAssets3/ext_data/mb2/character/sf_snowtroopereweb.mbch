//Siege class def file.

ClassInfo
{
	name				"sf_snowtroopereweb"
	weapons				WP_T21
	attributes			MB_ATT_BLASTER,2|MB_ATT_T21,3|MB_ATT_HEALING,2|MB_ATT_MAGNETIC_PLATING,1|MB_ATT_BLAST_ARMOUR,1|MB_ATT_AMMO,3
	holdables			HI_EWEB
	maxhealth			85
	maxarmor			85
