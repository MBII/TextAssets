//Siege class def file.

ClassInfo
{
	name				"YA_NRSapper"
	weapons				WP_BLASTER_PISTOL|WP_TRIP_MINE|WP_SONIC_NADE|WP_REAL_TD|WP_DET_PACK
	attributes			MB_ATT_ASSEMBLE,1|MB_ATT_PISTOL,2|MB_ATT_AMMO,3|MB_ATT_SONIC_DETONATOR,3|MB_ATT_HEALING,3|MB_ATT_BLAST_ARMOUR,1|MB_ATT_THERMALS,2|MB_ATT_FRAGS,2|MB_ATT_DET_PACK,2|MB_ATT_TRIP_MINES,8|MB_ATT_BACTA|MB_ATT_FORCEFIELD|MB_ATT_SENTRY
	//holdables			HI_MEDPAC|HI_SHIELD|HI_SENTRY_GUN
	maxhealth			80
	maxarmor			80
	model				"rebel_guerilla" 				//this is optional, if it's here it forces the model to this.
