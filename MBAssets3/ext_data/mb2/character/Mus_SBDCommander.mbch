ClassInfo
{
	name				"Mus_SBDCommander"
	weapons				WP_MELEE|WP_BLASTER_PISTOL|WP_DLT20A|WP_REAL_TD
	attributes			MB_ATT_PISTOL,2|MB_ATT_DLT20A,3|MB_ATT_THERMALS,1|MB_ATT_AMMO,3|MB_ATT_DODGE,2|MB_ATT_HEALING,2|MB_ATT_RALLY,1|MB_ATT_DISP_HEALTH,3
	maxhealth			100
