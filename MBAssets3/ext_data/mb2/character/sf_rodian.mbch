	attributes			MB_ATT_PISTOL,2|MB_ATT_BLASTER,2|MB_ATT_AMMO,3|MB_ATT_ASSEMBLE,1|MB_ATT_TRACKING_DART,1|MB_ATT_PROJECTILE_RIFLE,1
	maxhealth			100
