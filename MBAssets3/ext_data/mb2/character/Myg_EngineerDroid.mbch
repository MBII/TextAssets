ClassInfo
{
	name				"Myg_EngineerDroid"
	weapons				WP_MELEE|WP_BLASTER_PISTOL
	attributes			MB_ATT_PISTOL,2|MB_ATT_AMMO,2|MB_ATT_HEALING,3|MB_ATT_DISP_HEALTH,3|MB_ATT_EWEB|MB_ATT_SENTRY|MB_ATT_BASESEEKER
	//holdables			HI_EWEB|HI_SENTRY_GUN|HI_SEEKER
	maxhealth			80
	maxarmor			40
	model				"battledroid"
