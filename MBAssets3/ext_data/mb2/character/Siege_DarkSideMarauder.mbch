//Siege class def file.

ClassInfo
{
	name			"Siege_DarkSideMarauder"
	weapons			WP_SABER|WP_MELEE
	saber1			dual_1
	sabercolor		0
	saberstyle		SS_STAFF|SS_MEDIUM
	forcepowers		FP_SABER_OFFENSE,3|FP_SABER_DEFENSE,2|FP_SABERTHROW,2|FP_LEVITATION,2|FP_PUSH,2|FP_GRIP,3|FP_PULL,1|FP_LIGHTNING,2|FP_RAGE,3
	attributes		MB_ATT_FP_SABER_DEFENSE,2|MB_ATT_GUN_DEFENSE,2|MB_ATT_DEFLECT,2|MB_ATT_FORCEBLOCK,2|MB_ATT_FORCEFOCUS,2|MB_ATT_BUNNY_HOP,2|MB_ATT_FLOAT_HOP,1
	maxhealth		100
	maxarmor		0
	speed			1.2
	model			"reborn_new" 				//this is optional, if it's here it forces the model to this.
	skin			"default"					//this is optional, if it's here it forces the skin to this.
