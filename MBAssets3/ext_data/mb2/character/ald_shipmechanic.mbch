//Siege class def file.

ClassInfo
{
	name				"Ald_shipmechanic"
	weapons				WP_MELEE|WP_SHOTGUN|WP_SABER
	attributes			MB_ATT_AMMO,3|MB_ATT_SHOTGUN,2|MB_ATT_DISP_AMMO,3|MB_ATT_SENTRY|MB_ATT_DRONE
	//holdables			HI_SEEKER|HI_SENTRY_GUN
	saber1				ald_mwrench
	saberstyle			SS_MEDIUM
	maxhealth			125
	maxarmor			125
	speed				0.875
	model				"jedi_hf"				//this is optional, if it's here it forces the model to this.
	skin				"ponytail"					//this is optional, if it's here it forces the skin to this.
	uishader			"models/players/jedi_hf/mb2_icon_ponytail"
	MBClass				MB_CLASS_ELITETROOPER
	classNumberLimit	3
}

WeaponInfo0
{
	WeaponToReplace		WP_SHOTGUN					//Required: Weapon Slot of weapon you're replacing
	WeaponBasedOff		WP_BOWCASTER				//Required: For future use, should be the same as WeaponToReplace
	NewWorldModel		"models/weapons2/CR-1_cannon/rifle_w.glm"	//Required: New 3rd person/dropped weapon model
	NewViewModel		"models/weapons2/CR-1_cannon/rifle.md3"		//Required: New 1st person weapon model
	Icon				"gfx/hud/w_icon_cr1_blastcannon"			//Required: Weapon change icon
	WeaponName			"CR-1 Blast Cannon"			//Required: Weapon change display name
	altFireEnabled 		0
}

WeaponInfo1
{
	WeaponToReplace		WP_SABER					//Required: Weapon Slot of weapon you're replacing
	WeaponBasedOff		WP_SABER					//Required: For future use, should be the same as WeaponToReplace
	NewWorldModel		"models/weapons2/mwrench/mwrench.glm"	//Required: New 3rd person/dropped weapon model
	NewViewModel		"models/weapons2/dummy/dummy.md3"		//Required: New 1st person weapon model
	Icon				"gfx/hud/w_icon_mwrench"	//Required: Weapon change icon
	WeaponName			"Monkeywrench"				//Required: Weapon change display name
}

description	"Rebel Ship Mechanic

^2Weaponry:
- CR-1 Blast Cannon (2)
- Wrench

^6Inventory:
- Seeker Drone
- Portable Sentry Gun

^3Abilities:
- Ammo Dispenser [Press Use on Allies]

The men and women of the Rebel Alliance were fiercely dedicated to the principle of freedom, and would lay down their lives to win their objectives. Some were Imperials disillusioned with their government's tyranny."