ClassInfo
{
	name				"Echo2_ERebel2"
	weapons				WP_BLASTER_PISTOL|WP_MELEE|WP_BLASTER|WP_FRAG_NADE
	attributes			MB_ATT_PISTOL,3|MB_ATT_ASSEMBLE,1|MB_ATT_BLASTER,1|MB_ATT_AMMO,3|MB_ATT_DODGE,2|MB_ATT_FRAGS,1|MB_ATT_BACTA_BIG|MB_ATT_BINOCULARS|MB_ATT_FORCEFIELD
	//holdables			HI_MEDPAC_BIG|HI_BINOCULARS|HI_SHIELD
