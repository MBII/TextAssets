ClassInfo
{
	name				"duel_empt_Vader"
	weapons				WP_SABER|WP_MELEE
	attributes			MB_ATT_FP_SABER_DEFENSE,3|MB_ATT_GUN_DEFENSE,2|MB_ATT_FORCEFOCUS,1|MB_ATT_FORCEBLOCK,3
	saber1				saber_vader2
	sabercolor			0
	saberstyle			SS_MEDIUM|SS_STRONG
	forcepowers			FP_LEVITATION,2|FP_PUSH,3|FP_PULL,2|FP_GRIP,2|FP_SABER_OFFENSE,3|FP_SABER_DEFENSE,3
	forceregen			1.5
	maxhealth			100
	maxarmor			50
	modelscale			1.08
