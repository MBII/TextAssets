	name			"citadel_stormtrooper"
	weapons			WP_MELEE|WP_BLASTER
	attributes		MB_ATT_BLASTER,3|MB_ATT_AMMO,1|MB_ATT_ASSEMBLE,1|MB_ATT_CCTRAINING,2|MB_ATT_MAGNETIC_PLATING,1
	maxhealth		70
